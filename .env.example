# Copy this file to .env and fill in real values.
# The app force-loads the selected env file at startup.
# To use a different env file, set PI_TELEGRAM_BOT_ENV_PATH in the parent shell
# or service configuration before starting the bot. Do not set that override here.

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=replace-with-your-botfather-token

# Numeric Telegram user ID allowed to use the bot in private chat.
# This must be your personal numeric user ID, not your @username and not the bot ID.
# You can get it from @userinfobot or by checking Bot API getUpdates after messaging your bot.
TELEGRAM_AUTHORIZED_USER_ID=123456789

# Path to the single workspace this bot should control.
# Relative paths resolve from the repository root when you run the bot from this project.
PI_WORKSPACE_PATH=/absolute/path/to/your/pi-workspace

# Local app state file for the selected session and bot-owned pin metadata.
BOT_STATE_PATH=./data/state.json

# Optional override for the Pi agent directory.
# Leave blank to use the Pi SDK default on this machine.
PI_AGENT_DIR=

# Optional model used only for background session-title refinement.
# Use a provider-qualified value so the configured model source is explicit.
# This does not change the main Pi conversation model.
PI_SESSION_TITLE_REFINEMENT_MODEL=openai/gpt-5.4-mini

# Optional streaming cadence for in-progress Telegram replies.
# Minimum allowed value: 250
TELEGRAM_STREAM_THROTTLE_MS=1000

# Optional maximum characters per Telegram message chunk.
# Valid range: 512 to 4000
TELEGRAM_CHUNK_SIZE=3500
